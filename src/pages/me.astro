---
import Layout from "../layouts/Layout.astro";
import { LogOut, Mail, IdCard, Phone, CalendarDays, Clock } from "@lucide/astro";
---

<Layout title="Mi perfil">
  <main class="mx-auto max-w-3xl px-6 py-12">
    <header class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-indigo-600">Mi cuenta</p>
        <h1 class="mt-1 text-2xl font-semibold tracking-tight text-slate-900">
          Perfil
        </h1>
      </div>
      <button
        id="logout-btn"
        type="button"
        class="inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-3.5 py-2 text-sm font-medium text-slate-700 shadow-xs transition hover:bg-slate-50 focus:outline-none focus:ring-4 focus:ring-slate-100"
      >
        <LogOut size={16} />
        Cerrar sesión
      </button>
    </header>

    <section
      id="loading"
      class="mt-8 rounded-2xl border border-slate-200 bg-white p-12 text-center text-sm text-slate-500"
    >
      Cargando…
    </section>

    <section
      id="content"
      hidden
      class="mt-8 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm"
    >
      <div class="flex items-center gap-4 border-b border-slate-100 px-6 py-5">
        <div
          id="avatar"
          class="flex h-14 w-14 items-center justify-center rounded-full bg-indigo-600 text-lg font-semibold text-white"
        >
        </div>
        <div>
          <h2 id="full-name" class="text-base font-semibold text-slate-900"></h2>
          <p id="email-display" class="flex items-center gap-1.5 text-sm text-slate-500">
            <Mail size={14} />
            <span></span>
          </p>
        </div>
      </div>

      <dl class="divide-y divide-slate-100 text-sm">
        <div class="flex items-center justify-between px-6 py-4">
          <dt class="flex items-center gap-2 text-slate-500">
            <IdCard size={16} />
            Documento
          </dt>
          <dd id="document" class="font-medium text-slate-900"></dd>
        </div>
        <div class="flex items-center justify-between px-6 py-4">
          <dt class="flex items-center gap-2 text-slate-500">
            <Phone size={16} />
            Teléfono
          </dt>
          <dd id="phone" class="font-medium text-slate-900"></dd>
        </div>
        <div class="flex items-center justify-between px-6 py-4">
          <dt class="flex items-center gap-2 text-slate-500">
            <CalendarDays size={16} />
            Fecha de nacimiento
          </dt>
          <dd id="birth-date" class="font-medium text-slate-900"></dd>
        </div>
        <div class="flex items-center justify-between px-6 py-4">
          <dt class="flex items-center gap-2 text-slate-500">
            <Clock size={16} />
            Miembro desde
          </dt>
          <dd id="created-at" class="font-medium text-slate-900"></dd>
        </div>
      </dl>
    </section>
  </main>
</Layout>

<script>
  import { api, auth, ApiError } from "../lib/api";

  const token = auth.requireAuth();
  if (!token) {
    // requireAuth redirected; stop further work
  } else {
    const loading = document.getElementById("loading") as HTMLElement;
    const content = document.getElementById("content") as HTMLElement;
    const logoutBtn = document.getElementById("logout-btn") as HTMLButtonElement;

    logoutBtn.addEventListener("click", () => {
      auth.clearToken();
      window.location.href = "/login";
    });

    function formatDate(value: string | null, withTime = false): string {
      if (!value) return "—";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return date.toLocaleDateString("es-PE", {
        day: "2-digit",
        month: "long",
        year: "numeric",
        ...(withTime && { hour: "2-digit", minute: "2-digit" }),
      });
    }

    function initials(first: string, last: string): string {
      return `${first[0] ?? ""}${last[0] ?? ""}`.toUpperCase();
    }

    try {
      const me = await api.me(token);
      const p = me.profile;

      const fullName = p ? `${p.firstName} ${p.lastName}` : me.email;
      document.getElementById("full-name")!.textContent = fullName;
      document.querySelector("#email-display span")!.textContent = me.email;
      document.getElementById("avatar")!.textContent = p
        ? initials(p.firstName, p.lastName)
        : (me.email[0] ?? "?").toUpperCase();
      document.getElementById("document")!.textContent = p
        ? `${p.documentType} · ${p.documentNumber}`
        : "—";
      document.getElementById("phone")!.textContent = p?.phone ?? "—";
      document.getElementById("birth-date")!.textContent = formatDate(
        p?.birthDate ?? null,
      );
      document.getElementById("created-at")!.textContent = formatDate(
        p?.createdAt ?? null,
        true,
      );

      loading.hidden = true;
      content.hidden = false;
    } catch (err) {
      if (err instanceof ApiError && err.status === 401) {
        auth.clearToken();
        window.location.href = "/login";
      } else {
        loading.textContent =
          err instanceof ApiError ? err.messages.join(" · ") : "Error al cargar";
      }
    }
  }
</script>
