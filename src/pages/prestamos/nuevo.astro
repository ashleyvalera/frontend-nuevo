---
import AppLayout from "../../components/layout/AppLayout.astro";
import Card from "../../components/ui/Card.astro";
import Input from "../../components/ui/Input.astro";
import Button from "../../components/ui/Button.astro";
import { getAuthToken } from "../../lib/cookies";

const token = getAuthToken(Astro.cookies);
if (!token) {
  return Astro.redirect("/login");
}

let clientes = [];
let error = '';
let success = false;
let createdId = '';

const clientePreseleccionado = Astro.url.searchParams.get('clienteId') || '';

try {
  const res = await fetch('http://localhost:3000/usuarios', { headers: { 'Authorization': `Bearer ${token}` } });
  clientes = await res.json();
  if (!Array.isArray(clientes)) clientes = clientes.data || [];
} catch (e) {
  error = 'Error al cargar clientes';
}

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const data = {
      clienteId: formData.get("clienteId"),
      tipo: formData.get("tipo"),
      montoOriginal: parseFloat(formData.get("montoOriginal") as string),
      tasaInteres: parseFloat(formData.get("tasaInteres") as string),
      numeroCuotas: parseInt(formData.get("numeroCuotas") as string),
      cuotaFrecuencia: formData.get("cuotaFrecuencia"),
      fechaInicio: formData.get("fechaInicio"),
      descripcion: formData.get("descripcion") || undefined,
    };

    const res = await fetch('http://localhost:3000/prestamos', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(data),
    });

    if (res.ok) {
      const result = await res.json();
      createdId = result.id || result.data?.id;
      success = true;
    } else {
      const err = await res.json();
      error = err.message || 'Error al crear préstamo';
    }
  } catch (e) {
    error = 'Error al procesar la solicitud';
  }
}
---

<AppLayout title="Nuevo Préstamo" user={{ email: 'Usuario' }}>
  <div class="mb-6">
    <a href="/prestamos" class="text-sm text-teal-600 hover:text-teal-700 flex items-center gap-1">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a préstamos
    </a>
  </div>

  <div class="max-w-2xl">
    <h1 class="text-2xl font-bold text-slate-900 mb-6">Nuevo Préstamo</h1>

    {success ? (
      <Card>
        <div class="text-center py-8">
          <div class="mx-auto h-12 w-12 rounded-full bg-teal-100 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-slate-900 mb-2">Préstamo creado exitosamente</h2>
          <div class="flex gap-3 justify-center mt-4">
            <a href={`/prestamos/${createdId}`} class="text-teal-600 hover:text-teal-700 text-sm font-medium">
              Ver préstamo
            </a>
            <span class="text-slate-300">|</span>
            <a href="/prestamos" class="text-teal-600 hover:text-teal-700 text-sm font-medium">
              Ver préstamos
            </a>
          </div>
        </div>
      </Card>
    ) : (
      <Card>
        {error && (
          <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">{error}</div>
        )}

        <form method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">
              Cliente <span class="text-red-500">*</span>
            </label>
            <select
              name="clienteId"
              required
              class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-teal-500 focus:outline-none"
            >
              <option value="">Seleccionar cliente</option>
              {clientes.map((c: any) => (
                <option value={c.id} selected={c.id === clientePreseleccionado}>
                  {c.nombre} - {c.documentoNumero}
                </option>
              ))}
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">
              Tipo de préstamo <span class="text-red-500">*</span>
            </label>
            <select
              name="tipo"
              required
              class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-teal-500 focus:outline-none"
            >
              <option value="dinero">Dinero</option>
              <option value="artefacto">Artefacto</option>
            </select>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <Input
              name="montoOriginal"
              label="Monto"
              type="number"
              step="0.01"
              min="0"
              placeholder="0.00"
              required
            />
            <Input
              name="tasaInteres"
              label="Tasa mensual (%)"
              type="number"
              step="0.1"
              min="0"
              placeholder="5"
              required
            />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">
                Número de cuotas <span class="text-red-500">*</span>
              </label>
              <input
                type="number"
                name="numeroCuotas"
                min="1"
                required
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-teal-500 focus:outline-none"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1.5">
                Frecuencia <span class="text-red-500">*</span>
              </label>
              <select
                name="cuotaFrecuencia"
                required
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-teal-500 focus:outline-none"
              >
                <option value="mensual">Mensual</option>
                <option value="quincenal">Quincenal</option>
                <option value="semanal">Semanal</option>
              </select>
            </div>
          </div>

          <Input
            name="fechaInicio"
            label="Fecha de inicio"
            type="date"
            required
          />

          <Input
            name="descripcion"
            label="Descripción (opcional)"
            placeholder="Para artefactos: describe el objeto"
          />

          <div class="pt-4">
            <Button type="submit" variant="primary">
              Crear Préstamo
            </Button>
          </div>
        </form>
      </Card>
    )}
  </div>
</AppLayout>