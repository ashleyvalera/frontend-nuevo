---
import AppLayout from "../../components/layout/AppLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import Input from "../../components/ui/Input.astro";
import Modal from "../../components/ui/Modal.astro";
import { getAuthToken } from "../../lib/cookies";

const token = getAuthToken(Astro.cookies);
if (!token) {
  return Astro.redirect("/login");
}

const { id } = Astro.params;

let prestamo: any = null;
let pagos: any[] = [];
let cliente: any = null;
let error = '';
let success = false;

try {
  const [prestamoRes, pagosRes, clientesRes] = await Promise.all([
    fetch(`http://localhost:3000/prestamos/${id}`, { headers: { 'Authorization': `Bearer ${token}` } }),
    fetch(`http://localhost:3000/pagos?prestamoId=${id}`, { headers: { 'Authorization': `Bearer ${token}` } }),
    fetch('http://localhost:3000/usuarios', { headers: { 'Authorization': `Bearer ${token}` } }),
  ]);

  prestamo = await prestamoRes.json();
  const pagosData = await pagosRes.json();
  pagos = Array.isArray(pagosData) ? pagosData : pagosData.data || [];

  const clientes = await clientesRes.json();
  const clientesArr = Array.isArray(clientes) ? clientes : clientes.data || [];
  cliente = clientesArr.find((c: any) => c.id === prestamo?.clienteId);
} catch (e) {
  error = 'Error al cargar datos';
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  if (formData.get('action') === 'pago') {
    try {
      const data = {
        prestamoId: id,
        monto: parseFloat(formData.get('monto') as string),
        montoCapital: parseFloat(formData.get('montoCapital') as string) || 0,
        montoInteres: parseFloat(formData.get('montoInteres') as string) || 0,
        nota: formData.get('nota') || undefined,
        tipo: formData.get('monto') === formData.get('cuotaMonto') ? 'completo' : 'parcial',
        fechaPago: new Date().toISOString(),
      };

      const res = await fetch('http://localhost:3000/pagos', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        return Astro.redirect(`/prestamos/${id}`);
      } else {
        const err = await res.json();
        error = err.message || 'Error al registrar pago';
      }
    } catch (e) {
      error = 'Error al procesar pago';
    }
  }
}

const getBadgeVariant = (estado: string) => {
  if (estado === 'pagado') return 'success';
  if (estado === 'moroso') return 'danger';
  if (estado === 'cancelado') return 'neutral';
  return 'teal';
};
---

<AppLayout title="Préstamo" user={{ email: 'Usuario' }}>
  <div class="mb-6">
    <a href="/prestamos" class="text-sm text-teal-600 hover:text-teal-700 flex items-center gap-1">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a préstamos
    </a>
  </div>

  {error && (
    <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">{error}</div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <div class="lg:col-span-2">
      <Card class="p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-semibold text-slate-900">Detalles del Préstamo</h2>
          <Badge variant={getBadgeVariant(prestamo?.estado)}>{prestamo?.estado}</Badge>
        </div>

        <dl class="grid grid-cols-2 gap-4">
          <div>
            <dt class="text-xs font-medium text-slate-500 uppercase">Tipo</dt>
            <dd class="text-sm text-slate-900 capitalize">{prestamo?.tipo}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-slate-500 uppercase">Monto Original</dt>
            <dd class="text-sm text-slate-900">S/ {prestamo?.montoOriginal?.toFixed(2)}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-slate-500 uppercase">Saldo Pendiente</dt>
            <dd class="text-sm text-slate-900 font-semibold">S/ {prestamo?.montoActual?.toFixed(2)}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-slate-500 uppercase">Cuota</dt>
            <dd class="text-sm text-slate-900">S/ {prestamo?.cuotaMonto?.toFixed(2)}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-slate-500 uppercase">Tasa de Interés</dt>
            <dd class="text-sm text-slate-900">{prestamo?.tasaInteres}% mensual</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-slate-500 uppercase">Frecuencia</dt>
            <dd class="text-sm text-slate-900 capitalize">{prestamo?.cuotaFrecuencia}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-slate-500 uppercase">Fecha de Inicio</dt>
            <dd class="text-sm text-slate-900">
              {prestamo?.fechaInicio ? new Date(prestamo.fechaInicio).toLocaleDateString('es-PE') : '—'}
            </dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-slate-500 uppercase">Próximo Pago</dt>
            <dd class="text-sm text-slate-900">
              {prestamo?.proximaFechaPago ? new Date(prestamo.proximaFechaPago).toLocaleDateString('es-PE') : '—'}
            </dd>
          </div>
          {prestamo?.descripcion && (
            <div class="col-span-2">
              <dt class="text-xs font-medium text-slate-500 uppercase">Descripción</dt>
              <dd class="text-sm text-slate-900">{prestamo.descripcion}</dd>
            </div>
          )}
        </dl>
      </Card>
    </div>

    <div>
      <Card class="p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Cliente</h2>
        {cliente ? (
          <dl class="space-y-3">
            <div>
              <dt class="text-xs font-medium text-slate-500 uppercase">Nombre</dt>
              <dd class="text-sm text-slate-900">{cliente.nombre}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-slate-500 uppercase">Documento</dt>
              <dd class="text-sm text-slate-900">{cliente.documentoTipo} {cliente.documentoNumero}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-slate-500 uppercase">Teléfono</dt>
              <dd class="text-sm text-slate-900">{cliente.telefono}</dd>
            </div>
            <div>
              <a href={`/clientes/${cliente.id}`} class="text-sm text-teal-600 hover:text-teal-700">
                Ver cliente →
              </a>
            </div>
          </dl>
        ) : (
          <p class="text-sm text-slate-500">Sin datos del cliente</p>
        )}
      </Card>
    </div>
  </div>

  <Card>
    <div class="flex items-center justify-between p-4 border-b border-slate-200">
      <h2 class="text-lg font-semibold text-slate-900">Historial de Pagos</h2>
      {prestamo?.estado !== 'pagado' && prestamo?.estado !== 'cancelado' && (
        <button
          onclick="openModal('pago-modal')"
          class="inline-flex items-center gap-2 rounded-lg bg-teal-600 px-4 py-2 text-sm font-medium text-white hover:bg-teal-700"
        >
          Registrar Pago
        </button>
      )}
    </div>

    {pagos.length === 0 ? (
      <div class="p-8 text-center text-sm text-slate-500">
        No hay pagos registrados
      </div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Fecha</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Monto</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Tipo</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Nota</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {pagos.map((pago: any) => (
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-3 text-sm text-slate-600">
                  {pago.fechaPago ? new Date(pago.fechaPago).toLocaleDateString('es-PE') : '—'}
                </td>
                <td class="px-4 py-3 text-sm font-medium text-slate-900">
                  S/ {pago.monto?.toFixed(2)}
                </td>
                <td class="px-4 py-3">
                  <Badge variant={pago.tipo === 'completo' ? 'success' : 'warning'}>
                    {pago.tipo}
                  </Badge>
                </td>
                <td class="px-4 py-3 text-sm text-slate-600">{pago.nota || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </Card>

  <Modal id="pago-modal" title="Registrar Pago" size="md">
    <form method="POST" class="space-y-4">
      <input type="hidden" name="action" value="pago" />
      <input type="hidden" name="cuotaMonto" value={prestamo?.cuotaMonto} />
      
      <Input
        name="monto"
        label="Monto del pago"
        type="number"
        step="0.01"
        min="0"
        value={prestamo?.cuotaMonto}
        required
      />
      
      <Input
        name="montoCapital"
        label="Monto capital (opcional)"
        type="number"
        step="0.01"
        min="0"
        placeholder="Monto sin intereses"
      />
      
      <Input
        name="montoInteres"
        label="Monto intereses (opcional)"
        type="number"
        step="0.01"
        min="0"
        placeholder="Monto de intereses"
      />
      
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Nota (opcional)</label>
        <textarea
          name="nota"
          rows="2"
          placeholder="Ej: Cliente pagó solo una parte..."
          class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-teal-500 focus:outline-none"
        ></textarea>
      </div>
      
      <div class="flex gap-3 pt-2">
        <Button type="submit" variant="primary">Registrar</Button>
        <Button type="button" variant="ghost" onclick="closeModal('pago-modal')">Cancelar</Button>
      </div>
    </form>
  </Modal>
</AppLayout>