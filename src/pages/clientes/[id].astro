---
import AppLayout from "../../components/layout/AppLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import Input from "../../components/ui/Input.astro";
import { getAuthToken } from "../../lib/cookies";

const token = getAuthToken(Astro.cookies);
if (!token) {
  return Astro.redirect("/login");
}

const { id } = Astro.params;

let cliente = null;
let prestamos = [];
let error = '';

try {
  const [clienteRes, prestamosRes] = await Promise.all([
    fetch(`http://localhost:3000/usuarios/${id}`, { headers: { 'Authorization': `Bearer ${token}` } }),
    fetch(`http://localhost:3000/prestamos?clienteId=${id}`, { headers: { 'Authorization': `Bearer ${token}` } }),
  ]);
  
  cliente = await clienteRes.json();
  const prestamosData = await prestamosRes.json();
  prestamos = Array.isArray(prestamosData) ? prestamosData : prestamosData.data || [];
} catch (e) {
  error = 'Error al cargar datos';
}

const isEditing = Astro.url.searchParams.get('edit') === 'true';

if (Astro.request.method === 'POST' && isEditing) {
  try {
    const formData = await Astro.request.formData();
    const data = {
      nombre: formData.get("nombre"),
      telefono: formData.get("telefono"),
      direccion: formData.get("direccion"),
      nombreNegocio: formData.get("nombreNegocio") || undefined,
    };

    await fetch(`http://localhost:3000/usuarios/${id}`, {
      method: 'PUT',
      headers: {
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(data),
    });

    return Astro.redirect(`/clientes/${id}`);
  } catch (e) {
    error = 'Error al actualizar';
  }
}
---

<AppLayout title="Cliente" user={{ email: 'Usuario' }}>
  <div class="mb-6">
    <a href="/clientes" class="text-sm text-teal-600 hover:text-teal-700 flex items-center gap-1">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a clientes
    </a>
  </div>

  {error && (
    <div class="mb-4 rounded-lg bg-red-50 p-4 text-sm text-red-700">{error}</div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <Card class="p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-semibold text-slate-900">Datos del Cliente</h2>
          {!isEditing && (
            <a href={`/clientes/${id}?edit=true`} class="text-sm text-teal-600 hover:text-teal-700">
              Editar
            </a>
          )}
        </div>

        {isEditing ? (
          <form method="POST" class="space-y-4">
            <input type="hidden" name="edit" value="true" />
            <Input name="nombre" label="Nombre" value={cliente?.nombre} required />
            <Input name="telefono" label="Teléfono" value={cliente?.telefono} required />
            <Input name="direccion" label="Dirección" value={cliente?.direccion} required />
            <Input name="nombreNegocio" label="Negocio" value={cliente?.nombreNegocio} />
            <div class="flex gap-2">
              <Button type="submit">Guardar</Button>
              <a href={`/clientes/${id}`} class="px-4 py-2 text-sm text-slate-600 hover:text-slate-700">
                Cancelar
              </a>
            </div>
          </form>
        ) : (
          <dl class="space-y-4">
            <div>
              <dt class="text-xs font-medium text-slate-500 uppercase">Nombre</dt>
              <dd class="text-sm text-slate-900">{cliente?.nombre || '—'}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-slate-500 uppercase">Documento</dt>
              <dd class="text-sm text-slate-900">{cliente?.documentoTipo} {cliente?.documentoNumero}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-slate-500 uppercase">Teléfono</dt>
              <dd class="text-sm text-slate-900">{cliente?.telefono || '—'}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-slate-500 uppercase">Dirección</dt>
              <dd class="text-sm text-slate-900">{cliente?.direccion || '—'}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-slate-500 uppercase">Negocio</dt>
              <dd class="text-sm text-slate-900">{cliente?.nombreNegocio || '—'}</dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-slate-500 uppercase">Estado</dt>
              <dd class="mt-1">
                <Badge variant={cliente?.estado === 'activo' ? 'teal' : 'neutral'}>
                  {cliente?.estado}
                </Badge>
              </dd>
            </div>
          </dl>
        )}
      </Card>
    </div>

    <div class="lg:col-span-2">
      <Card>
        <div class="flex items-center justify-between p-4 border-b border-slate-200">
          <h2 class="text-lg font-semibold text-slate-900">Préstamos</h2>
          <a href={`/prestamos/nuevo?clienteId=${id}`} class="text-sm text-teal-600 hover:text-teal-700 font-medium">
            + Nuevo Préstamo
          </a>
        </div>

        {prestamos.length === 0 ? (
          <div class="p-8 text-center text-sm text-slate-500">
            No hay préstamos registrados
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-slate-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Tipo</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Monto</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Saldo</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Cuota</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Estado</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500">Acciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {prestamos.map((p: any) => (
                  <tr class="hover:bg-slate-50">
                    <td class="px-4 py-3 text-sm text-slate-900 capitalize">{p.tipo}</td>
                    <td class="px-4 py-3 text-sm text-slate-600">S/ {p.montoOriginal?.toFixed(2)}</td>
                    <td class="px-4 py-3 text-sm text-slate-600">S/ {p.montoActual?.toFixed(2)}</td>
                    <td class="px-4 py-3 text-sm text-slate-600">S/ {p.cuotaMonto?.toFixed(2)}</td>
                    <td class="px-4 py-3">
                      <Badge variant={
                        p.estado === 'pagado' ? 'success' :
                        p.estado === 'moroso' ? 'danger' :
                        p.estado === 'cancelado' ? 'neutral' : 'teal'
                      }>
                        {p.estado}
                      </Badge>
                    </td>
                    <td class="px-4 py-3">
                      <a href={`/prestamos/${p.id}`} class="text-sm font-medium text-teal-600 hover:text-teal-700">
                        Ver
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </Card>
    </div>
  </div>
</AppLayout>